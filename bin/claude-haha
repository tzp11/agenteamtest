#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BUN_PATH="/home/tzp/work/agent/MAi_Coding/bun-linux-x64/bun"

# Force recovery CLI (simple readline REPL, no Ink TUI)
if [[ "${CLAUDE_CODE_FORCE_RECOVERY_CLI:-0}" == "1" ]]; then
  exec "$BUN_PATH" --env-file="$ROOT_DIR/.env" --preload="$ROOT_DIR/preload.ts" "$ROOT_DIR/src/localRecoveryCli.ts" "$@"
fi

# Default: full CLI with Ink TUI
exec "$BUN_PATH" --env-file="$ROOT_DIR/.env" --preload="$ROOT_DIR/preload.ts" "$ROOT_DIR/src/entrypoints/cli.tsx" "$@"
